{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Genesis Grid",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "shell": { "open": true },
      "fs": { "all": true, "scope": ["$APPDATA/genesis-grid/*"] },
      "dialog": { "all": true }
    },
    "bundle": {
      "active": true,
      "identifier": "com.genesisgridlabs.app",
      "copyright": "© 2026 Genesis Grid Labs™. All Rights Reserved.",
      "publisher": "Genesis Grid Labs",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "targets": ["nsis", "msi", "dmg", "appimage", "deb"]
    },
    "windows": [
      {
        "title": "Genesis Grid",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://genesisgridlabs.xyz/updater.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFMDdFNjhEMjdFRkRFNjEKUldSaDN1OG5qZVlITG1ZWWxsRlZ1MTlacVpSUy9GSGJTZnpWaUo2VUpYa21wSVcvTjJsd0hXWVkK"
    }
  }
}
